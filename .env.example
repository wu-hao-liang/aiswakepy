APP_ENV=production
FLASK_ENV=production
SECRET_KEY=change-me
UPLOAD_FOLDER=/data/uploads
DATA_ROOT=/data
HOST_DATA_DIR=/opt/apps/aiswakepy/data
MAX_UPLOAD_FILE_BYTES=104857600
MAX_SESSION_BYTES=314572800
SESSION_TTL_SECONDS=3600
PORT=8050

# Gunicorn runtime settings.
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=300
